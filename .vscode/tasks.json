{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Android: Build Debug",
      "type": "shell",
      "command": "./gradlew",
      "args": ["assembleDebug"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Android: Install Debug",
      "type": "shell",
      "command": "./gradlew",
      "args": ["installDebug"],
      "problemMatcher": []
    },
    {
      "label": "Android: Start App",
      "type": "shell",
      "command": "adb",
      "args": [
        "shell",
        "am",
        "start",
        "-n",
        "com.ahmad.girum/.MainActivity"
      ],
      "problemMatcher": []
    },
    {
      "label": "Android: Run App",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Android: Install Debug",
        "Android: Start App"
      ],
      "problemMatcher": []
    },
    {
      "label": "Android: Launch Small_Phone Emulator",
      "type": "shell",
      "command": "emulator",
      "args": ["-avd", "Small_Phone", "-no-boot-anim", "-gpu", "host"],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Android: List Devices",
      "type": "shell",
      "command": "adb",
      "args": ["devices"],
      "problemMatcher": []
    }
  ]
}
